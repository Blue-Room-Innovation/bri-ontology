@prefix : <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#> .
@prefix bcf: <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl> .

<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl>
    a owl:Ontology ;
    rdfs:label "BIM BCF Ontology" ;
    rdfs:comment "Ontology for BIM Collaboration Format (BCF) resources aligned with the BIM BCF SHACL model." ;
    owl:versionInfo "0.1" .

#################################################################
#    classes
#################################################################

bcf:bcfModel a owl:Class ;
    rdfs:comment "Root container class for BIM BCF model resources." .

bcf:document a owl:Class ;
    rdfs:comment "Document metadata entry with filename, description, and GUID." .

bcf:extensions a owl:Class ;
    rdfs:comment "Extension catalog holder." .

bcf:project a owl:Class ;
    rdfs:comment "Project details with project ID and optional name." .

bcf:version a owl:Class ;
    rdfs:comment "Version payload with required version identifier." .

bcf:markup a owl:Class ;
    rdfs:comment "Main BCF markup class containing header and topic." .

bcf:header a owl:Class ;
    rdfs:comment "Header section containing referenced files." .

bcf:topic a owl:Class ;
    rdfs:comment "Core issue/topic class with metadata, workflow state, comments, and viewpoints." .

bcf:bimSnippet a owl:Class ;
    rdfs:comment "BIM snippet metadata containing reference and schema details." .

bcf:file a owl:Class ;
    rdfs:comment "Referenced file metadata class in the markup header." .

bcf:viewPoint a owl:Class ;
    rdfs:comment "Viewpoint resource with viewpoint file, snapshot, index, and GUID." .

bcf:documentReference a owl:Class ;
    rdfs:comment "Document reference class for either internal document GUID or external URL." .

bcf:relatedTopicRef a owl:Class ;
    rdfs:comment "Reference class identifying a related topic by GUID." .

bcf:comment a owl:Class ;
    rdfs:comment "Comment resource with authoring and modification metadata." .

bcf:commentViewpointRef a owl:Class ;
    rdfs:comment "Reference from comment to a viewpoint identified by GUID." .

bcf:visualizationInfo a owl:Class ;
    rdfs:comment "Visualization payload including camera configuration and overlays." .

bcf:orthogonalCamera a owl:Class ;
    rdfs:comment "Orthogonal camera definition." .

bcf:perspectiveCamera a owl:Class ;
    rdfs:comment "Perspective camera definition." .

bcf:point a owl:Class ;
    rdfs:comment "3D point represented by X, Y, and Z coordinates." .

bcf:direction a owl:Class ;
    rdfs:comment "3D direction vector represented by X, Y, and Z components." .

bcf:components a owl:Class ;
    rdfs:comment "Components definition containing selection, visibility, and coloring sections." .

bcf:viewSetupHints a owl:Class ;
    rdfs:comment "Viewer hints for visibility of spaces, boundaries, and openings." .

bcf:componentVisibility a owl:Class ;
    rdfs:comment "Default visibility and exception settings for components." .

bcf:coloringEntry a owl:Class ;
    rdfs:comment "Single color rule entry linking components and a color value." .

bcf:component a owl:Class ;
    rdfs:comment "IFC component reference with optional originating system metadata." .

bcf:line a owl:Class ;
    rdfs:comment "Line overlay defined by start and end points." .

bcf:clippingPlane a owl:Class ;
    rdfs:comment "Clipping plane defined by location and direction." .

bcf:bitmap a owl:Class ;
    rdfs:comment "Bitmap overlay with placement, orientation, format, and size." .

#################################################################
#    object properties
#################################################################

bcf:documents a owl:ObjectProperty ;
    rdfs:domain bcf:bcfModel ;
    rdfs:range bcf:document ;
    rdfs:comment "Links a BCF model directly to document entries." .

bcf:extensions a owl:ObjectProperty ;
    rdfs:domain bcf:bcfModel ;
    rdfs:range bcf:extensions ;
    rdfs:comment "Links a BCF model to extension values." .

bcf:markup a owl:ObjectProperty ;
    rdfs:domain bcf:bcfModel ;
    rdfs:range bcf:markup ;
    rdfs:comment "Links a BCF model to its main markup content." .

bcf:version a owl:ObjectProperty ;
    rdfs:domain bcf:bcfModel ;
    rdfs:range bcf:version ;
    rdfs:comment "Links a BCF model to its declared version payload." .

bcf:visualizationInfo a owl:ObjectProperty ;
    rdfs:domain bcf:bcfModel ;
    rdfs:range bcf:visualizationInfo ;
    rdfs:comment "Links a BCF model to viewpoint visualization information." .

bcf:project a owl:ObjectProperty ;
    rdfs:domain bcf:bcfModel ;
    rdfs:range bcf:project ;
    rdfs:comment "Links project info to the concrete project descriptor." .

bcf:header a owl:ObjectProperty ;
    rdfs:domain bcf:markup ;
    rdfs:range bcf:header ;
    rdfs:comment "Links markup to optional header information." .

bcf:topic a owl:ObjectProperty ;
    rdfs:domain bcf:markup ;
    rdfs:range bcf:topic ;
    rdfs:comment "Links markup to its main topic issue payload." .

bcf:files a owl:ObjectProperty ;
    rdfs:domain bcf:header ;
    rdfs:range bcf:file ;
    rdfs:comment "Links a header directly to file entries." .

bcf:bimSnippet a owl:ObjectProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range bcf:bimSnippet ;
    rdfs:comment "Links topic to its BIM snippet description." .

bcf:documentReferences a owl:ObjectProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range bcf:documentReference ;
    rdfs:comment "Links a topic directly to document reference entries." .

bcf:relatedTopics a owl:ObjectProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range bcf:relatedTopicRef ;
    rdfs:comment "Links a topic directly to related topic references." .

bcf:comments a owl:ObjectProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range bcf:comment ;
    rdfs:comment "Links a topic directly to comment entries." .

bcf:viewpoints a owl:ObjectProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range bcf:viewPoint ;
    rdfs:comment "Links a topic directly to viewpoint entries." .

bcf:viewpoint a owl:ObjectProperty ;
    rdfs:domain bcf:comment ;
    rdfs:range bcf:commentViewpointRef ;
    rdfs:comment "Links a comment to a referenced viewpoint." .

bcf:components a owl:ObjectProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:visualizationInfo bcf:coloringEntry )
    ] ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf ( bcf:components bcf:component )
    ] ;
    rdfs:comment "Links visualization info or a coloring entry to components according to the SHACL model." .

bcf:lines a owl:ObjectProperty ;
    rdfs:domain bcf:visualizationInfo ;
    rdfs:range bcf:line ;
    rdfs:comment "Links visualization info directly to line entries." .

bcf:clippingPlanes a owl:ObjectProperty ;
    rdfs:domain bcf:visualizationInfo ;
    rdfs:range bcf:clippingPlane ;
    rdfs:comment "Links visualization info directly to clipping plane entries." .

bcf:bitmaps a owl:ObjectProperty ;
    rdfs:domain bcf:visualizationInfo ;
    rdfs:range bcf:bitmap ;
    rdfs:comment "Links visualization info directly to bitmap entries." .

bcf:orthogonalCamera a owl:ObjectProperty ;
    rdfs:domain bcf:visualizationInfo ;
    rdfs:range bcf:orthogonalCamera ;
    rdfs:comment "Associates visualization info with an orthogonal camera definition." .

bcf:perspectiveCamera a owl:ObjectProperty ;
    rdfs:domain bcf:visualizationInfo ;
    rdfs:range bcf:perspectiveCamera ;
    rdfs:comment "Associates visualization info with a perspective camera definition." .

bcf:cameraViewPoint a owl:ObjectProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:orthogonalCamera bcf:perspectiveCamera )
    ] ;
    rdfs:range bcf:point ;
    rdfs:comment "Camera position in 3D space." .

bcf:cameraDirection a owl:ObjectProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:orthogonalCamera bcf:perspectiveCamera )
    ] ;
    rdfs:range bcf:direction ;
    rdfs:comment "Camera forward direction vector." .

bcf:cameraUpVector a owl:ObjectProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:orthogonalCamera bcf:perspectiveCamera )
    ] ;
    rdfs:range bcf:direction ;
    rdfs:comment "Camera up direction vector." .

bcf:selection a owl:ObjectProperty ;
    rdfs:domain bcf:components ;
    rdfs:range bcf:component ;
    rdfs:comment "Links components directly to selected components." .

bcf:visibility a owl:ObjectProperty ;
    rdfs:domain bcf:components ;
    rdfs:range bcf:componentVisibility ;
    rdfs:comment "Visibility rules for components within a viewpoint." .

bcf:coloring a owl:ObjectProperty ;
    rdfs:domain bcf:components ;
    rdfs:range bcf:coloringEntry ;
    rdfs:comment "Links components directly to coloring entries." .

bcf:viewSetupHints a owl:ObjectProperty ;
    rdfs:domain bcf:componentVisibility ;
    rdfs:range bcf:viewSetupHints ;
    rdfs:comment "Viewer hints for spaces, openings, and boundaries." .

bcf:exceptions a owl:ObjectProperty ;
    rdfs:domain bcf:componentVisibility ;
    rdfs:range bcf:component ;
    rdfs:comment "Links component visibility directly to exception components." .

bcf:startPoint a owl:ObjectProperty ;
    rdfs:domain bcf:line ;
    rdfs:range bcf:point ;
    rdfs:comment "Start point of a line segment." .

bcf:endPoint a owl:ObjectProperty ;
    rdfs:domain bcf:line ;
    rdfs:range bcf:point ;
    rdfs:comment "End point of a line segment." .

bcf:location a owl:ObjectProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:clippingPlane bcf:bitmap )
    ] ;
    rdfs:range bcf:point ;
    rdfs:comment "3D location used by clipping planes and bitmap placement." .

bcf:direction a owl:ObjectProperty ;
    rdfs:domain bcf:clippingPlane ;
    rdfs:range bcf:direction ;
    rdfs:comment "Normal direction of a clipping plane." .

bcf:normal a owl:ObjectProperty ;
    rdfs:domain bcf:bitmap ;
    rdfs:range bcf:direction ;
    rdfs:comment "Normal vector of a bitmap overlay plane." .

bcf:up a owl:ObjectProperty ;
    rdfs:domain bcf:bitmap ;
    rdfs:range bcf:direction ;
    rdfs:comment "Up vector of a bitmap overlay plane." .

#################################################################
#    datatype properties
#################################################################

bcf:filename a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:document bcf:file )
    ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:name ;
    rdfs:comment "Filename associated with a document or file entry." .

bcf:description a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:document bcf:topic bcf:documentReference )
    ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:description, dcterms:description ;
    rdfs:comment "Human-readable description text." .

bcf:guid a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "Globally unique identifier represented as text." .

bcf:topicTypes a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dcterms:type ;
    rdfs:comment "Topic type value available in extensions." .

bcf:topicStatuses a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:comment "Topic status value available in extensions." .

bcf:priorities a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:comment "Priority value available in extensions." .

bcf:topicLabels a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:keywords, dcterms:subject ;
    rdfs:comment "Topic label value available in extensions." .

bcf:users a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:comment "User identifier value available in extensions." .

bcf:snippetTypes a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dcterms:type ;
    rdfs:comment "Snippet type value available in extensions." .

bcf:stages a owl:DatatypeProperty ;
    rdfs:domain bcf:extensions ;
    rdfs:range xsd:string ;
    rdfs:comment "Stage value available in extensions." .

bcf:name a owl:DatatypeProperty ;
    rdfs:domain bcf:project ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:name ;
    rdfs:comment "Human-readable name of the project." .

bcf:projectId a owl:DatatypeProperty ;
    rdfs:domain bcf:project ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "Identifier for the project." .

bcf:versionId a owl:DatatypeProperty ;
    rdfs:domain bcf:version ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "Version identifier string for BCF payload." .

bcf:referenceLinks a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:url, dcterms:references ;
    rdfs:comment "External reference URL associated with a topic." .

bcf:title a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:name, dcterms:title ;
    rdfs:comment "Short human-readable title of a topic." .

bcf:priority a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:comment "Priority value used in a topic." .

bcf:index a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:topic bcf:viewPoint )
    ] ;
    rdfs:range xsd:int ;
    rdfs:subPropertyOf schema:position ;
    rdfs:comment "Integer sort/index value for topic or viewpoint." .

bcf:labels a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:keywords, dcterms:subject ;
    rdfs:comment "Label attached directly to a topic." .

bcf:creationDate a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf schema:dateCreated, dcterms:created ;
    rdfs:comment "Timestamp when the topic was created." .

bcf:creationAuthor a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:creator, schema:author ;
    rdfs:comment "Author who created the topic." .

bcf:modifiedDate a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:topic bcf:comment )
    ] ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf schema:dateModified, dcterms:modified ;
    rdfs:comment "Timestamp of the latest modification." .

bcf:modifiedAuthor a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:topic bcf:comment )
    ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:author ;
    rdfs:comment "Author of the latest modification." .

bcf:dueDate a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Requested due date for the topic." .

bcf:assignedTo a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:comment "Assignee identifier for the topic." .

bcf:stage a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:comment "Stage value used in a topic." .

bcf:serverAssignedId a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "Server-assigned topic identifier." .

bcf:topicType a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dcterms:type ;
    rdfs:comment "Topic type value used in a topic." .

bcf:topicStatus a owl:DatatypeProperty ;
    rdfs:domain bcf:topic ;
    rdfs:range xsd:string ;
    rdfs:comment "Topic status value used in a topic." .

bcf:reference a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:bimSnippet bcf:file bcf:bitmap )
    ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:contentUrl ;
    rdfs:comment "Reference string (filename, URI, or path) used by snippets, files, and bitmaps." .

bcf:referenceSchema a owl:DatatypeProperty ;
    rdfs:domain bcf:bimSnippet ;
    rdfs:range xsd:string ;
    rdfs:comment "Schema identifier associated with a BIM snippet." .

bcf:isExternal a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:bimSnippet bcf:file )
    ] ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indicates whether a referenced resource is external to the BCF package." .

bcf:ifcProject a owl:DatatypeProperty ;
    rdfs:domain bcf:file ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "IFC project GUID associated with a file entry." .

bcf:ifcSpatialStructureElement a owl:DatatypeProperty ;
    rdfs:domain bcf:file ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "IFC spatial structure element GUID associated with a file entry." .

bcf:documentGuid a owl:DatatypeProperty ;
    rdfs:domain bcf:documentReference ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "GUID of an internal document referenced by a topic." .

bcf:url a owl:DatatypeProperty ;
    rdfs:domain bcf:documentReference ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:url, dcterms:references ;
    rdfs:comment "URL of an external document referenced by a topic." .

bcf:date a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:file bcf:comment )
    ] ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp associated with a file or comment entry." .

bcf:author a owl:DatatypeProperty ;
    rdfs:domain bcf:comment ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:author ;
    rdfs:comment "Author identifier for a comment entry." .

bcf:commentText a owl:DatatypeProperty ;
    rdfs:domain bcf:comment ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:text ;
    rdfs:comment "Textual body of a comment entry." .

bcf:viewpointFile a owl:DatatypeProperty ;
    rdfs:domain bcf:viewPoint ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:contentUrl ;
    rdfs:comment "Filename or path of the viewpoint file associated with a viewpoint resource." .

bcf:snapshot a owl:DatatypeProperty ;
    rdfs:domain bcf:viewPoint ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:image, schema:contentUrl ;
    rdfs:comment "Snapshot image filename associated with a viewpoint." .

bcf:viewToWorldScale a owl:DatatypeProperty ;
    rdfs:domain bcf:orthogonalCamera ;
    rdfs:range xsd:double ;
    rdfs:comment "Visible vertical size in world units for orthogonal camera." .

bcf:fieldOfView a owl:DatatypeProperty ;
    rdfs:domain bcf:perspectiveCamera ;
    rdfs:range xsd:double ;
    rdfs:comment "Vertical field of view angle in degrees for perspective camera." .

bcf:aspectRatio a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:orthogonalCamera bcf:perspectiveCamera )
    ] ;
    rdfs:range xsd:double ;
    rdfs:comment "Width/height aspect ratio of the camera view." .

bcf:x a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:point bcf:direction )
    ] ;
    rdfs:range xsd:double ;
    rdfs:comment "X coordinate component." .

bcf:y a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:point bcf:direction )
    ] ;
    rdfs:range xsd:double ;
    rdfs:comment "Y coordinate component." .

bcf:z a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bcf:point bcf:direction )
    ] ;
    rdfs:range xsd:double ;
    rdfs:comment "Z coordinate component." .

bcf:spacesVisible a owl:DatatypeProperty ;
    rdfs:domain bcf:viewSetupHints ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Viewer hint indicating whether spaces are visible." .

bcf:spaceBoundariesVisible a owl:DatatypeProperty ;
    rdfs:domain bcf:viewSetupHints ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Viewer hint indicating whether space boundaries are visible." .

bcf:openingsVisible a owl:DatatypeProperty ;
    rdfs:domain bcf:viewSetupHints ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Viewer hint indicating whether openings are visible." .

bcf:defaultVisibility a owl:DatatypeProperty ;
    rdfs:domain bcf:componentVisibility ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Default visibility state for components in a viewpoint." .

bcf:originatingSystem a owl:DatatypeProperty ;
    rdfs:domain bcf:component ;
    rdfs:range xsd:string ;
    rdfs:comment "Name of the source system for a component reference." .

bcf:authoringToolId a owl:DatatypeProperty ;
    rdfs:domain bcf:component ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "Identifier of the component in the authoring tool." .

bcf:ifcGuid a owl:DatatypeProperty ;
    rdfs:domain bcf:component ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:identifier, dcterms:identifier ;
    rdfs:comment "IFC GUID of the component." .

bcf:colorValue a owl:DatatypeProperty ;
    rdfs:domain bcf:coloringEntry ;
    rdfs:range xsd:string ;
    rdfs:comment "Hexadecimal RGB or RGBA color value used in a coloring rule." .

bcf:format a owl:DatatypeProperty ;
    rdfs:domain bcf:bitmap ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:fileFormat, dcterms:format ;
    rdfs:comment "Bitmap image format (for example, png or jpg)." .

bcf:height a owl:DatatypeProperty ;
    rdfs:domain bcf:bitmap ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf schema:height ;
    rdfs:comment "Height of the bitmap overlay in world units." .