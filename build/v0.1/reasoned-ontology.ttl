                                                                                                  <http://www.w3.org/2004/02/skos/core#inScheme> <https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/discharge-means-code.ttl#DischargeMeansCodeScheme> ;
                                                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "ZTE"@en .


###  https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/iso3166-iAlpha2.ttl#ISO3166Alpha2Scheme
<https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/iso3166-iAlpha2.ttl#ISO3166Alpha2Scheme> rdf:type owl:NamedIndividual ,
                                                                                                                      <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                                                                             dcterms:source <https://www.iso.org/obp/ui/#search> ;
                                                                                                             <http://www.w3.org/2004/02/skos/core#definition> "Standardized two-letter country codes established by ISO 3166-1 Alpha-2."@en ;
                                                                                                             <http://www.w3.org/2004/02/skos/core#note> "Referenced by properties such as :flag within the Digital MARPOL Waste Passport ontology, indicating the flag state of a ship using standardized ISO 3166-1 Alpha-2 codes."@en ;
                                                                                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "ISO 3166-1 Alpha-2 Country Codes"@en ;
                                                                                                             <http://www.w3.org/2004/02/skos/core#scopeNote> "This scheme references the official ISO publication and does not reproduce the codes locally. Implementations should resolve codes directly from the ISO OBP or an authorized registry."@en .


###  https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/residue-type-code.ttl#ResidueSubtypeCodeScheme
<https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/residue-type-code.ttl#ResidueSubtypeCodeScheme> rdf:type owl:NamedIndividual ,
                                                                                                                             <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                                                                                    rdfs:comment "Controlled vocabulary defining subtypes of residues generated on ships, used to refine MARPOL waste categorization."@en ;
                                                                                                                    <http://www.w3.org/2004/02/skos/core#definition> "A code that specifies the subtype of residue, providing a more granular classification of the waste material."@en ;
                                                                                                                    <http://www.w3.org/2004/02/skos/core#note> "Linked to the property :subtypeCode in the Digital MARPOL Waste Passport ontology, constraining allowed values to this controlled vocabulary."@en ;
                                                                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Residue Subtype Code"@en .


###  https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/residue-type-code.ttl#ResidueTypeCodeScheme
<https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/residue-type-code.ttl#ResidueTypeCodeScheme> rdf:type owl:NamedIndividual ,
                                                                                                                          <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                                                                                 rdfs:comment "Defines the main waste types under MARPOL Annexes, such as hazardous, non-hazardous, sludge, and wastewater residues."@en ;
