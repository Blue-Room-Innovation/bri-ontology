                                                                                                        rdfs:range <https://ontology.untp.io/core/Party> ;
                                                                                                        rdfs:comment "The role of the involved party, as defined by the regulatory framework." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#ship
<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#ship> rdf:type owl:ObjectProperty ;
