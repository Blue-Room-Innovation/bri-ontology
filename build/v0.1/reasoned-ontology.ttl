###  http://purl.org/dc/terms/type
dcterms:type rdf:type owl:DatatypeProperty .


###  http://schema.org/addressLocality
<http://schema.org/addressLocality> rdf:type owl:DatatypeProperty .


###  http://schema.org/postalCode
<http://schema.org/postalCode> rdf:type owl:DatatypeProperty .


###  http://schema.org/streetAddress
<http://schema.org/streetAddress> rdf:type owl:DatatypeProperty .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#aspectRatio
bcf:aspectRatio rdf:type owl:DatatypeProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( bcf:orthogonalCamera
                                            bcf:perspectiveCamera
                                          )
                            ] ;
                rdfs:range xsd:double ;
                rdfs:comment "Width/height aspect ratio of the camera view." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#assignedTo
bcf:assignedTo rdf:type owl:DatatypeProperty ;
               rdfs:domain bcf:topic ;
               rdfs:range xsd:string ;
               rdfs:comment "Assignee identifier for the topic." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#author
bcf:author rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf schema:author ;
           rdfs:domain bcf:comment ;
           rdfs:range xsd:string ;
           rdfs:comment "Author identifier for a comment entry." .


