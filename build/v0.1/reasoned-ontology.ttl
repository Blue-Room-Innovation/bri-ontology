@prefix : <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#> .
@prefix bcf: <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl> .

<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl> rdf:type owl:Ontology ;
                                                                                 rdfs:comment "Ontology for BIM Collaboration Format (BCF) resources aligned with the BIM BCF SHACL model." ;
                                                                                 rdfs:label "BIM BCF Ontology" ;
                                                                                 owl:versionInfo "0.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
<http://www.w3.org/2004/02/skos/core#note> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#related
<http://www.w3.org/2004/02/skos/core#related> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
<http://www.w3.org/2004/02/skos/core#scopeNote> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#bimSnippet
bcf:bimSnippet rdf:type owl:ObjectProperty ;
               rdfs:domain bcf:topic ;
               rdfs:range bcf:bimSnippet .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#bitmaps
bcf:bitmaps rdf:type owl:ObjectProperty ;
            rdfs:domain bcf:visualizationInfo ;
            rdfs:range bcf:bitmap ;
            rdfs:comment "Links visualization info directly to bitmap entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#cameraDirection
bcf:cameraDirection rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( bcf:orthogonalCamera
                                                bcf:perspectiveCamera
                                              )
                                ] ;
                    rdfs:range bcf:direction ;
                    rdfs:comment "Camera forward direction vector." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#cameraUpVector
bcf:cameraUpVector rdf:type owl:ObjectProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( bcf:orthogonalCamera
                                               bcf:perspectiveCamera
                                             )
                               ] ;
                   rdfs:range bcf:direction ;
                   rdfs:comment "Camera up direction vector." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#cameraViewPoint
bcf:cameraViewPoint rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( bcf:orthogonalCamera
                                                bcf:perspectiveCamera
                                              )
                                ] ;
                    rdfs:range bcf:point ;
                    rdfs:comment "Camera position in 3D space." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#clippingPlanes
bcf:clippingPlanes rdf:type owl:ObjectProperty ;
                   rdfs:domain bcf:visualizationInfo ;
                   rdfs:range bcf:clippingPlane ;
                   rdfs:comment "Links visualization info directly to clipping plane entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#coloring
bcf:coloring rdf:type owl:ObjectProperty ;
             rdfs:domain bcf:components ;
             rdfs:range bcf:coloringEntry ;
             rdfs:comment "Links components directly to coloring entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#comments
bcf:comments rdf:type owl:ObjectProperty ;
             rdfs:domain bcf:topic ;
             rdfs:range bcf:comment ;
             rdfs:comment "Links a topic directly to comment entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#components
bcf:components rdf:type owl:ObjectProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( bcf:coloringEntry
                                           bcf:visualizationInfo
                                         )
                           ] ;
               rdfs:range [ rdf:type owl:Class ;
                            owl:unionOf ( bcf:component
                                          bcf:components
                                        )
                          ] .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#direction
bcf:direction rdf:type owl:ObjectProperty ;
              rdfs:domain bcf:clippingPlane ;
              rdfs:range bcf:direction .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#documentReferences
bcf:documentReferences rdf:type owl:ObjectProperty ;
                       rdfs:domain bcf:topic ;
                       rdfs:range bcf:documentReference ;
                       rdfs:comment "Links a topic directly to document reference entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#documents
bcf:documents rdf:type owl:ObjectProperty ;
              rdfs:domain bcf:bcfModel ;
              rdfs:range bcf:document ;
              rdfs:comment "Links a BCF model directly to document entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#endPoint
bcf:endPoint rdf:type owl:ObjectProperty ;
             rdfs:domain bcf:line ;
             rdfs:range bcf:point ;
             rdfs:comment "End point of a line segment." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#exceptions
bcf:exceptions rdf:type owl:ObjectProperty ;
               rdfs:domain bcf:componentVisibility ;
               rdfs:range bcf:component ;
               rdfs:comment "Links component visibility directly to exception components." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#extensions
bcf:extensions rdf:type owl:ObjectProperty ;
               rdfs:domain bcf:bcfModel ;
               rdfs:range bcf:extensions .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#file
bcf:file rdf:type owl:ObjectProperty ;
         rdfs:domain bcf:header ;
         rdfs:range bcf:file .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#header
bcf:header rdf:type owl:ObjectProperty ;
           rdfs:domain bcf:markup ;
           rdfs:range bcf:header .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#lines
bcf:lines rdf:type owl:ObjectProperty ;
          rdfs:domain bcf:visualizationInfo ;
          rdfs:range bcf:line ;
          rdfs:comment "Links visualization info directly to line entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#location
bcf:location rdf:type owl:ObjectProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( bcf:bitmap
                                         bcf:clippingPlane
                                       )
                         ] ;
             rdfs:range bcf:point ;
             rdfs:comment "3D location used by clipping planes and bitmap placement." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#markup
bcf:markup rdf:type owl:ObjectProperty ;
           rdfs:domain bcf:bcfModel ;
           rdfs:range bcf:markup .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#normal
bcf:normal rdf:type owl:ObjectProperty ;
           rdfs:domain bcf:bitmap ;
           rdfs:range bcf:direction ;
           rdfs:comment "Normal vector of a bitmap overlay plane." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#orthogonalCamera
bcf:orthogonalCamera rdf:type owl:ObjectProperty ;
                     rdfs:domain bcf:visualizationInfo ;
                     rdfs:range bcf:orthogonalCamera .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#perspectiveCamera
bcf:perspectiveCamera rdf:type owl:ObjectProperty ;
                      rdfs:domain bcf:visualizationInfo ;
                      rdfs:range bcf:perspectiveCamera .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#project
bcf:project rdf:type owl:ObjectProperty ;
            rdfs:domain bcf:projectInfo ;
            rdfs:range bcf:project .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#projectInfo
bcf:projectInfo rdf:type owl:ObjectProperty ;
                rdfs:domain bcf:bcfModel ;
                rdfs:range bcf:projectInfo .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#relatedTopics
bcf:relatedTopics rdf:type owl:ObjectProperty ;
                  rdfs:domain bcf:topic ;
                  rdfs:range bcf:relatedTopicRef ;
                  rdfs:comment "Links a topic directly to related topic references." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#selection
bcf:selection rdf:type owl:ObjectProperty ;
              rdfs:domain bcf:components ;
              rdfs:range bcf:component ;
              rdfs:comment "Links components directly to selected components." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#startPoint
bcf:startPoint rdf:type owl:ObjectProperty ;
               rdfs:domain bcf:line ;
               rdfs:range bcf:point ;
               rdfs:comment "Start point of a line segment." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#topic
bcf:topic rdf:type owl:ObjectProperty ;
          rdfs:domain bcf:markup ;
          rdfs:range bcf:topic .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#up
bcf:up rdf:type owl:ObjectProperty ;
       rdfs:domain bcf:bitmap ;
       rdfs:range bcf:direction ;
       rdfs:comment "Up vector of a bitmap overlay plane." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#version
bcf:version rdf:type owl:ObjectProperty ;
            rdfs:domain bcf:bcfModel ;
            rdfs:range bcf:version .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#viewSetupHints
bcf:viewSetupHints rdf:type owl:ObjectProperty ;
                   rdfs:domain bcf:componentVisibility ;
                   rdfs:range bcf:viewSetupHints .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#viewpoint
bcf:viewpoint rdf:type owl:ObjectProperty ;
              rdfs:domain bcf:comment ;
              rdfs:range bcf:commentViewpointRef ;
              rdfs:comment "Links a comment to a referenced viewpoint." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#viewpoints
bcf:viewpoints rdf:type owl:ObjectProperty ;
               rdfs:domain bcf:topic ;
               rdfs:range bcf:viewPoint ;
               rdfs:comment "Links a topic directly to viewpoint entries." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#visibility
bcf:visibility rdf:type owl:ObjectProperty ;
               rdfs:domain bcf:components ;
               rdfs:range bcf:componentVisibility ;
               rdfs:comment "Visibility rules for components within a viewpoint." .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/bim-bcf.ttl#visualizationInfo
bcf:visualizationInfo rdf:type owl:ObjectProperty ;
                      rdfs:domain bcf:bcfModel ;
                      rdfs:range bcf:visualizationInfo .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#contactPoint
<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#contactPoint> rdf:type owl:ObjectProperty ;
                                                                                                                rdfs:domain <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#AuthorizedParty> ;
                                                                                                                rdfs:range <https://ontology.untp.io/core/Link> ;
                                                                                                                rdfs:comment "Contact information for the authorized party, represented as a link." .


