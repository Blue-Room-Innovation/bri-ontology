         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( bcf:comment
                                     bcf:file
                                   )
                     ] ;
         rdfs:range xsd:dateTime ;
         rdfs:comment "Timestamp associated with a file or comment entry." .


