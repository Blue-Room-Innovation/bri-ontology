###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#arrivalPort
<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#arrivalPort> rdf:type owl:DatatypeProperty ;
                                                                                                               rdfs:domain <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#MarpolWaste> ;
                                                                                                               rdfs:range xsd:string ;
                                                                                                               rdfs:comment "The port of arrival for the ship, identified using the UN/LOCODE format (e.g., `ESPMI`)." ;
                                                                                                               <http://www.w3.org/2004/02/skos/core#related> <https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/unlocode.ttl#UNLocodeScheme> .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#deliveryType
<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#deliveryType> rdf:type owl:DatatypeProperty ;
                                                                                                                rdfs:domain <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#MarpolWaste> ;
                                                                                                                rdfs:range xsd:string ;
                                                                                                                rdfs:comment "Code indicating the type of delivery method used for the waste, based on a local codelist (e.g., `ZTO`)." ;
                                                                                                                <http://www.w3.org/2004/02/skos/core#related> <https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/delivery-type-code.ttl#DeliveryTypeCodeScheme> .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#dischargeMeans
<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#dischargeMeans> rdf:type owl:DatatypeProperty ;
                                                                                                                  rdfs:domain <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#ResidueInformation> ;
                                                                                                                  rdfs:range xsd:string ;
                                                                                                                  rdfs:comment "The method used to discharge the residue, identified by a local codelist code (e.g., `ZTE`)." ;
                                                                                                                  <http://www.w3.org/2004/02/skos/core#related> <https://blue-room-innovation.github.io/bri-ontology/codelists/v0.1/discharge-means-code.ttl.ttl#DischargeMeansCodeScheme> .


###  https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#flag
<https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#flag> rdf:type owl:DatatypeProperty ;
                                                                                                        rdfs:domain <https://blue-room-innovation.github.io/bri-ontology/ontology/v0.1/digitalMarpolWastePassport.ttl#Ship> ;
